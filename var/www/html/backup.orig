<?php
declare(strict_types=1);

include 'menu.php';

function renderPageStart(string $title): void
{
    echo '<html lang="en"><head><meta charset="utf-8"><title>WiPi Netbooter</title>';
    echo '<link rel="stylesheet" href="css/sidebarstyles.css">';
    echo '</head><body>';
    echo '<section><center>';
    echo '<h1><a href="setup.php">' . htmlspecialchars($title, ENT_QUOTES, 'UTF-8') . '</a></h1><br>';
}

function renderPageEnd(): void
{
    echo '</center></section></body></html>';
}

function renderBox(string $content, string $width = '350px'): void
{
    echo '<div class="box2" style="width:' . $width . ';max-width:95%;padding:12px 16px;box-sizing:border-box;text-align:center;">';
    echo $content;
    echo '</div><br>';
}

renderPageStart('Backup Menu');

renderBox('<a href="backup_create.php">Create Backup</a>');
renderBox('<a href="backup_restore.php">Restore Backup</a>');
renderBox('<a href="setup.php">Back</a>');

renderPageEnd();
?>
